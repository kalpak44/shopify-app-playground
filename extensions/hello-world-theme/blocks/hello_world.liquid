<div
  style="
    padding: 16px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 8px;
    background: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
  "
>
  <strong>{{ block.settings.heading }}</strong>
  <p>{{ 'hello_world.message' | t }}</p>
</div>

{% schema %}
{
  "name": "Hello World",
  "target": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Hello from my app" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#f5f7ff" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#1e3a8a" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#111827" }
  ]
}
{% endschema %}
